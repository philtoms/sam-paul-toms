{
  "name": "sam",
  "version": "1.0.0",
  "description": "Sam Paul Toms — Portfolio",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:watch": "vitest",
    "clean:worktrees": "git worktree list --porcelain | grep '^worktree ' | grep -v $(pwd) | cut -d' ' -f2 | xargs -I {} git worktree remove '{}' && git branch --list 'kb/*' | sed 's/^..//' | xargs git branch -D",
    "generate:waveforms": "R2_PUBLIC_URL=${R2_PUBLIC_URL:-public/audio-samples} node scripts/generate-waveforms.cjs",
    "wav2mp3": "node scripts/wav2mp3.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/sitemap": "^3.7.2",
    "@preact/signals": "^2.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^5.18.1",
    "howler": "^2.2.4",
    "preact": "^10.29.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/howler": "^2.2.13",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "vitest": "^4.1.6",
    "zod": "^3.25.76"
  }
}
