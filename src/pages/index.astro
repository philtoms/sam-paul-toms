---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sam — Music">
  <!-- Hero Section -->
  <section class="section">
    <div class="container">
      <div style="animation: fade-in-up 0.5s ease forwards;">
        <h1 class="heading-1">Sam</h1>
        <p class="mt-4" style="color: var(--color-text-secondary); font-size: var(--text-lg);">
          Music portfolio — design system showcase
        </p>
      </div>
    </div>
  </section>

  <!-- Color Swatches -->
  <section class="section">
    <div class="container">
      <h2 class="heading-2 mb-6">Color Palette</h2>
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-3);">
        <div style="width: 80px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: var(--radius-lg); background-color: var(--color-bg); border: 1px solid var(--color-border);"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">bg</span>
        </div>
        <div style="width: 80px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: var(--radius-lg); background-color: var(--color-bg-elevated);"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">elevated</span>
        </div>
        <div style="width: 80px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: var(--radius-lg); background-color: var(--color-bg-overlay);"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">overlay</span>
        </div>
        <div style="width: 80px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: var(--radius-lg); background-color: var(--color-accent);"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">accent</span>
        </div>
        <div style="width: 80px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: var(--radius-lg); background-color: var(--color-success);"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">success</span>
        </div>
        <div style="width: 80px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: var(--radius-lg); background-color: var(--color-error);"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">error</span>
        </div>
        <div style="width: 80px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: var(--radius-lg); background-color: var(--color-warning);"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">warning</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Typography Scale -->
  <section class="section">
    <div class="container">
      <h2 class="heading-2 mb-6">Typography Scale</h2>
      <div style="display: flex; flex-direction: column; gap: var(--space-4);">
        <p style="font-size: var(--text-xs); color: var(--color-text-tertiary);">Text XS — 12px</p>
        <p style="font-size: var(--text-sm); color: var(--color-text-tertiary);">Text SM — 14px</p>
        <p style="font-size: var(--text-base);">Text Base — 16px (primary)</p>
        <p style="font-size: var(--text-lg);">Text LG — 18px</p>
        <p style="font-size: var(--text-xl);">Text XL — 20px</p>
        <p style="font-size: var(--text-2xl);">Text 2XL — 24px</p>
        <p style="font-size: var(--text-3xl);">Text 3XL — 30px</p>
        <p style="font-size: var(--text-4xl);">Text 4XL — 36px</p>
        <p style="font-size: var(--text-5xl);">Text 5XL — 48px</p>
        <p style="font-size: var(--text-6xl);">Text 6XL — 60px</p>
      </div>
      <div style="margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-2);">
        <p style="color: var(--color-text);">Primary text color</p>
        <p style="color: var(--color-text-secondary);">Secondary text color</p>
        <p style="color: var(--color-text-tertiary);">Tertiary text color</p>
      </div>
    </div>
  </section>

  <!-- Heading Classes -->
  <section class="section">
    <div class="container">
      <h2 class="heading-2 mb-6">Heading Classes</h2>
      <div style="display: flex; flex-direction: column; gap: var(--space-4);">
        <h1 class="heading-1">Heading 1 — Display</h1>
        <h2 class="heading-2">Heading 2 — Section Title</h2>
        <h3 class="heading-3">Heading 3 — Subsection</h3>
      </div>
    </div>
  </section>

  <!-- Card Example -->
  <section class="section">
    <div class="container">
      <h2 class="heading-2 mb-6">Card Component</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-6);">
        <div class="card" style="padding: var(--space-6);">
          <div class="artwork-container" style="margin-bottom: var(--space-4);">
            <div style="width: 100%; height: 100%; background: linear-gradient(135deg, var(--color-accent), var(--color-accent-hover)); display: flex; align-items: center; justify-content: center;">
              <span style="font-size: var(--text-2xl); font-weight: 700;">🎵</span>
            </div>
          </div>
          <h3 class="heading-3" style="margin-bottom: var(--space-2);">Album Title</h3>
          <p style="color: var(--color-text-secondary); font-size: var(--text-sm);">Artist name — 2024</p>
          <div style="display: flex; gap: var(--space-2); margin-top: var(--space-3);">
            <span class="pill">Electronic</span>
            <span class="pill">Ambient</span>
          </div>
        </div>
        <div class="card" style="padding: var(--space-6);">
          <div class="artwork-container" style="margin-bottom: var(--space-4);">
            <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #1a1a2e, #16213e); display: flex; align-items: center; justify-content: center;">
              <span style="font-size: var(--text-2xl); font-weight: 700;">🎸</span>
            </div>
          </div>
          <h3 class="heading-3" style="margin-bottom: var(--space-2);">Another Release</h3>
          <p style="color: var(--color-text-secondary); font-size: var(--text-sm);">Artist name — 2023</p>
          <div style="display: flex; gap: var(--space-2); margin-top: var(--space-3);">
            <span class="pill">Indie</span>
            <span class="pill">Rock</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pill Examples -->
  <section class="section">
    <div class="container">
      <h2 class="heading-2 mb-6">Pills / Badges</h2>
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
        <span class="pill">Electronic</span>
        <span class="pill">Ambient</span>
        <span class="pill">Indie</span>
        <span class="pill">Rock</span>
        <span class="pill">Experimental</span>
        <span class="pill">Lo-fi</span>
      </div>
    </div>
  </section>

  <!-- Animation Examples -->
  <section class="section">
    <div class="container">
      <h2 class="heading-2 mb-6">Animations</h2>
      <div style="display: flex; gap: var(--space-8); flex-wrap: wrap;">
        <div style="text-align: center;">
          <div style="width: 60px; height: 60px; border-radius: var(--radius-full); background-color: var(--color-accent); animation: play-pulse 1.5s ease-in-out infinite;"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">play-pulse</span>
        </div>
        <div style="text-align: center;">
          <div style="width: 60px; height: 60px; border-radius: var(--radius-lg); background-color: var(--color-bg-elevated); border: 1px solid var(--color-border); animation: spin 1s linear infinite;"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">spin</span>
        </div>
        <div style="text-align: center;">
          <div style="width: 120px; height: 20px; border-radius: var(--radius-full); background: linear-gradient(90deg, var(--color-bg-elevated) 25%, var(--color-border) 50%, var(--color-bg-elevated) 75%); background-size: 200% 100%; animation: shimmer 2s linear infinite;"></div>
          <span style="font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; margin-top: var(--space-2);">shimmer</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
