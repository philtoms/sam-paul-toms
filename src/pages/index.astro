---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import CompactBio from '../components/CompactBio.astro';
import SocialLinksBar from '../components/SocialLinksBar.astro';
import PlaylistAccordion from '../components/PlaylistAccordion';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { getCollection, render } from 'astro:content';
import { buildTrackFromContent } from '../scripts/audio-helpers';
import type { Track } from '../components/AudioPlayer/types';

// Fetch about content for the AboutModal
const aboutEntries = await getCollection('about');
const aboutEntry = aboutEntries[0];
const { Content: AboutContent } = await render(aboutEntry);
const { title: aboutTitle, photo: aboutPhoto, photoAlt: aboutPhotoAlt, genreTags: aboutGenreTags, pressQuotes: aboutPressQuotes } = aboutEntry.data;

// Fetch works sections in display order
const sectionOrder = [
  'documentary',
  'film',
  'library',
  'trailers-themes-idents',
];
const worksEntries = await getCollection('works');
const sortedWorks = worksEntries.sort(
  (a, b) =>
    sectionOrder.indexOf(a.data.slug) - sectionOrder.indexOf(b.data.slug),
);

// Build section data for the accordion (display-only track info)
const sections = sortedWorks.map((entry) => ({
  title: entry.data.title,
  slug: entry.data.slug,
  description: entry.data.description,
  tracks: entry.data.tracks.map((t) => ({
    title: t.title,
    subtitle: t.subtitle,
    duration: t.duration,
    icon: t.icon ?? 'music',
  })),
}));

// Build playable tracks map: section slug → Track[] for audio dispatch
const playableTracksMap: Record<string, Track[]> = {};
for (const entry of sortedWorks) {
  playableTracksMap[entry.data.slug] = entry.data.tracks.map((track, i) =>
    buildTrackFromContent(track, entry.data.slug, i, 'Sam', '/favicon.svg'),
  );
}

// Build ALL playable tracks for "Play All" button (concatenated across sections in order)
const allTracks: Track[] = sortedWorks.flatMap((entry) =>
  entry.data.tracks.map((track, i) =>
    buildTrackFromContent(track, entry.data.slug, i, 'Sam', '/favicon.svg'),
  ),
);
const allTracksJson = JSON.stringify(allTracks);

// YouTube video
const youtubeUrl = 'https://www.youtube.com/watch?v=xlt63O1YvSM';

// Bio summary
const bioSummary =
  'Sam is a multidisciplinary artist and producer based in the spaces between genres. Drawing from a deep well of influences, Sam crafts sound worlds that are at once intimate and expansive.';
---

<BaseLayout
  title="Sam Paul Toms — Composer & Producer"
  description="Official music portfolio of Sam Paul Toms. Listen to tracks, albums, and EPs."
  image="/favicon.svg"
  type="website"
  aboutTitle={aboutTitle}
  aboutPhoto={aboutPhoto}
  aboutPhotoAlt={aboutPhotoAlt}
  aboutGenreTags={aboutGenreTags}
  aboutPressQuotes={aboutPressQuotes}
>
  <HeroBanner />

  <main class="relative z-10 mt-[calc(100vw*9/16-4rem)] md:mt-[calc(100vw*9/21-4rem)] max-w-[1052px] mx-auto">
    {/* Bio Section */}
    <section class="section">
      <div class="container">
        <CompactBio summary={bioSummary}>
          <div class="mt-6">
            <SocialLinksBar allTracksJson={allTracksJson} />
          </div>
        </CompactBio>
      </div>
    </section>

    {/* Playlist Accordion */}
    <section class="section">
      <div class="container max-w-3xl">
        <PlaylistAccordion
          client:load
          sections={sections}
          playableTracksMap={playableTracksMap}
          allTracks={allTracks}
        />
      </div>
    </section>

    {/* YouTube Embed */}
    <section class="section">
      <div class="container max-w-3xl">
        <YouTubeEmbed url={youtubeUrl} title="Sam Paul Toms — Featured Video" />
      </div>
    </section>
  </main>

  {/* Hidden bio content for AboutModal to read from DOM */}
  <div id="about-bio-content" style="display:none">
    <AboutContent />
  </div>
</BaseLayout>
