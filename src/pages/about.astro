---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BioSection from '../components/BioSection.astro';
import GenreTags from '../components/GenreTags.astro';
import PressQuotes from '../components/PressQuotes.astro';
import ContactForm from '../components/ContactForm.astro';

const aboutEntries = await getCollection('about');
const entry = aboutEntries[0];
const { Content } = await render(entry);
const { title, photo, photoAlt, genreTags, pressQuotes } = entry.data;
---

<BaseLayout title="Sam Paul Toms — About">
  <main class="max-w-5xl mx-auto px-6 py-16">
    <BioSection title={title} photo={photo} photoAlt={photoAlt}>
      <Content />
    </BioSection>

    <div class="mt-8">
      <GenreTags tags={genreTags} />
    </div>

    <section class="mt-16">
      <h2 class="text-2xl font-bold text-white mb-8">Press</h2>
      <PressQuotes quotes={pressQuotes} />
    </section>

    <section class="mt-16 max-w-2xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-8">Get In Touch</h2>
      <ContactForm />
    </section>
  </main>
</BaseLayout>
