---
import { getCollection } from 'astro:content';
import ReleasesLayout from '../../layouts/ReleasesLayout.astro';
import ReleaseCard from '../../components/ReleaseCard.astro';
import { DEFAULT_SITE_NAME } from '../../scripts/seo-helpers';

const allReleases = await getCollection('releases');
const sorted = allReleases.sort(
  (a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime(),
);

const albums = sorted.filter((r) => r.data.type === 'album');
const eps = sorted.filter((r) => r.data.type === 'ep');
const singles = sorted.filter((r) => r.data.type === 'single');

const siteName = import.meta.env.PUBLIC_SITE_NAME || DEFAULT_SITE_NAME;
---

<ReleasesLayout
  title={`${siteName} — Releases`}
  description={`Browse all releases by ${siteName} — albums, EPs, and singles with streaming links.`}
  type="website"
>
  <h1 class="text-3xl font-bold tracking-tight mb-8">Releases</h1>

  {albums.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-text/70 mb-4">Albums</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {albums.map((release) => (
          <ReleaseCard release={release} />
        ))}
      </div>
    </section>
  )}

  {eps.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-text/70 mb-4">EPs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {eps.map((release) => (
          <ReleaseCard release={release} />
        ))}
      </div>
    </section>
  )}

  {singles.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-text/70 mb-4">Singles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {singles.map((release) => (
          <ReleaseCard release={release} />
        ))}
      </div>
    </section>
  )}
</ReleasesLayout>
