---
import { getCollection, render } from 'astro:content';
import ReleasesLayout from '../../layouts/ReleasesLayout.astro';
import StreamingLinks from '../../components/StreamingLinks.astro';
import TrackList from '../../components/TrackList.astro';
import { generateMusicAlbumSchema } from '../../scripts/structured-data';
import { buildTrackFromContent } from '../../scripts/audio-helpers';
import type { Track } from '../../components/AudioPlayer/types';
import { DEFAULT_SITE_NAME } from '../../scripts/seo-helpers';

const { slug } = Astro.params;

const allReleases = await getCollection('releases');
const release = allReleases.find((r) => r.id === slug);

if (!release) {
  return Astro.redirect('/releases');
}

const {
  title,
  artist,
  releaseDate,
  type,
  artwork,
  description,
  tracks,
  streamingLinks,
} = release.data;

const playableTracks: Track[] = tracks.map((track, i) =>
  buildTrackFromContent(track, slug!, i, artist, artwork),
);

const formattedDate = releaseDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const typeBadge: Record<string, string> = {
  album: 'ALBUM',
  ep: 'EP',
  single: 'SINGLE',
};

const { Content } = await render(release);

const siteUrl = Astro.site?.href || 'https://sampaultoms.com/';
const albumSchema = generateMusicAlbumSchema(release.data, siteUrl);

const siteName = import.meta.env.PUBLIC_SITE_NAME || DEFAULT_SITE_NAME;

const ogType = type === 'single' ? 'music.song' : 'music.album';
const metaDescription = description || `Listen to ${title} by ${siteName}.`;
---

<ReleasesLayout
  title={`${siteName} — ${title}`}
  description={metaDescription}
  image={artwork}
  type={ogType}
  structuredData={albumSchema}
>
  <nav class="mb-8 text-sm text-text/50">
    <a href="/" class="hover:text-accent transition-colors">{siteName}</a>
    <span class="mx-2">/</span>
    <a href="/releases" class="hover:text-accent transition-colors">Releases</a>
    <span class="mx-2">/</span>
    <span class="text-text/80">{title}</span>
  </nav>

  <div class="flex flex-col md:flex-row gap-8 md:gap-12 mb-10">
    {/* Album artwork */}
    <div class="shrink-0 flex justify-center md:justify-start">
      <img
        src={artwork}
        alt={`${title} artwork`}
        class="w-full max-w-[400px] md:max-w-[500px] rounded-lg shadow-2xl"
      />
    </div>

    {/* Release metadata */}
    <div class="flex flex-col justify-center">
      <span class="text-xs font-semibold tracking-wider text-accent mb-2">
        {typeBadge[type]}
      </span>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-2">
        {title}
      </h1>
      <p class="text-lg text-text/70 mb-1">{artist}</p>
      <p class="text-sm text-text/40 mb-6">{formattedDate}</p>

      {
        description && (
          <p class="text-text/60 leading-relaxed mb-6 max-w-lg">
            {description}
          </p>
        )
      }

      {
        streamingLinks && (
          <div class="mb-4">
            <h2 class="text-xs font-semibold tracking-wider text-text/40 uppercase mb-3">
              Listen Now
            </h2>
            <StreamingLinks links={streamingLinks} />
          </div>
        )
      }
    </div>
  </div>

  {/* Markdown body (extended description) */}
  <div class="prose prose-invert prose-sm max-w-none mb-10 text-text/60">
    <Content />
  </div>

  {/* Track listing */}
  <section>
    <h2 class="text-lg font-semibold mb-4">
      {type === 'single' ? 'Track' : 'Tracks'}
    </h2>
    <TrackList tracks={tracks} playableTracks={playableTracks} />
  </section>
</ReleasesLayout>
