---
/**
 * HeroBanner — Fixed-position hero with scroll-over parallax effect.
 *
 * The hero is pinned to the top of the viewport as a fixed background layer.
 * Main page content scrolls over it with a solid background, covering the hero
 * while it simultaneously fades out and shrinks via scroll-driven JS.
 *
 * Features:
 * - Fixed positioning (40dvh mobile / 60dvh desktop)
 * - Full-bleed banner cover image with dark overlay
 * - Large artist name + tagline
 * - Scroll-driven opacity fade and slight scale-down
 */
---

<div id="hero-banner" class="fixed top-0 left-0 right-0 z-0 flex h-[40dvh] items-center justify-center md:h-[60dvh]">
  <img src="/images/banner/spt_low_res.png" alt="" class="absolute inset-0 h-full w-full object-cover" />
  <div class="absolute inset-0 bg-black/40"></div>
  <div class="hero-bottom-fade absolute inset-0" style="background: linear-gradient(to bottom, transparent 50%, var(--color-bg) 100%);"></div>
  <div class="text-center">
    <h1 class="text-6xl font-bold tracking-tight text-text md:text-7xl">Sam Paul Toms</h1>
    <p class="mt-4 text-lg text-text/70">Composer & Producer</p>
  </div>
</div>

<script>
  /**
   * Scroll-driven hero fade effect.
   * As the user scrolls, the banner fades out (opacity 1→0) and
   * slightly shrinks (scale 1→0.95) over ~300px of scroll distance.
   */
  const hero = document.getElementById('hero-banner');
  if (hero) {
    let ticking = false;

    const onScroll = () => {
      if (ticking) return;
      ticking = true;

      requestAnimationFrame(() => {
        const fraction = Math.min(window.scrollY / 300, 1);
        hero.style.opacity = String(1 - fraction);
        hero.style.transform = `scale(${1 - fraction * 0.05})`;
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
