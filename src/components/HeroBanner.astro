---
/**
 * HeroBanner — Fixed-position hero with scroll-over parallax effect.
 *
 * The hero is pinned to the top of the viewport as a fixed background layer.
 * Main page content scrolls over it with a solid background, covering the hero
 * while it simultaneously fades out and shrinks via scroll-driven JS.
 *
 * Features:
 * - Fixed positioning with aspect-ratio-driven height
 * - Full-bleed banner cover image with cinematic crop
 * - Bottom-edge gradient fade aligned to image edge
 * - Scroll-driven opacity fade with cubic ease-out easing
 * - Scale range 1.1→1.0 so image always fills container (no edge reveal)
 * - Post-scroll inertia via lerp-based rAF loop for cinematic drift
 */
---

<div
  id="hero-banner"
  class="fixed top-0 left-0 right-0 z-0 flex aspect-[16/5] items-center justify-center overflow-hidden md:aspect-[27/9]"
>
  <img src="/images/banner/SPT_v111.png" alt="" class="h-full w-full min-w-full object-cover" />
  <div class="absolute inset-0 bg-black/20"></div>
  <div class="hero-top-fade absolute left-0 right-0 top-0"></div>
  <div class="hero-bottom-fade absolute bottom-0 left-0 right-0"></div>
</div>

<script>
  /**
   * Scroll-driven hero fade effect with inertia.
   *
   * As the user scrolls, the banner fades out (opacity 1→0) and
   * shrinks (scale 1.1→1.0) over ~300px of scroll distance.
   *
   * A cubic ease-out curve is applied to the raw scroll fraction for a
   * fast-attack, slow-settle ramp. The rendered opacity/scale lerp towards
   * the target via requestAnimationFrame, creating post-scroll inertia —
   * the banner drifts and settles after the user stops scrolling.
   */
  const hero = document.getElementById('hero-banner');
  if (hero) {
    /** Cubic ease-out: fast attack, slow settle */
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    let target = 0; // eased scroll fraction (immediate)
    let current = 0; // lerped value (animated)
    let rafId = 0;

    const apply = () => {
      hero.style.opacity = String(1 - current);
      hero.style.transform = `scale(${1.1 - current * 0.1})`;
    };

    const loop = () => {
      current += (target - current) * 0.1;

      if (Math.abs(target - current) > 0.001) {
        apply();
        rafId = requestAnimationFrame(loop);
      } else {
        current = target;
        apply();
        rafId = 0;
      }
    };

    const onScroll = () => {
      const raw = Math.min(window.scrollY / 300, 1);
      target = easeOut(raw);

      if (!rafId) {
        rafId = requestAnimationFrame(loop);
      }
    };

    // Set initial state
    apply();

    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
