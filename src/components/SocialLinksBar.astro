---
/**
 * SocialLinksBar — Play/Pause toggle button + social/streaming icon links.
 *
 * A pure Astro component with a client-side script handling the Play All / Pause
 * toggle button. The button uses Preact signals (isPlaying, playbackState, tracks)
 * and the effect() function to reactively sync its icon and aria-label with the
 * Player bar's transport state — no direct coupling to the audio engine.
 *
 * Behavior:
 * - **Idle / no tracks loaded:** Clicking dispatches `audio-player:play` with the
 *   full track list (startIndex: 0), opening the Player bar and starting playback.
 * - **Track loaded:** Clicking dispatches `audio-player:toggle` to toggle
 *   play/pause, mirroring the Player bar's transport button exactly.
 * - **Icon sync:** A Preact `effect()` reactively swaps the SVG between a play
 *   triangle (▶) and pause bars (⏸) based on the `isPlaying` signal.
 * - **aria-label sync:** "Play all tracks" when idle, "Play" when paused with
 *   a track loaded, "Pause" when playing.
 *
 * Each social icon link reveals its platform name via a smooth CSS
 * opacity transition on hover (200ms ease). The label appears below the
 * icon in a white-bordered pill. Icons remain stationary — no layout shift.
 *
 * Props:
 * - allTracksJson: Pre-serialized JSON string of Track[] objects.
 *   The script tag parses it and dispatches the audio-player:play event.
 */

interface Props {
  allTracksJson: string;
}

const { allTracksJson } = Astro.props;

// Social/streaming links sourced from environment variables.
// Icons are conditionally rendered — hidden entirely when the URL is empty
// so the layout adapts gracefully when URLs are added later.
const socialImdb = import.meta.env.PUBLIC_SOCIAL_IMDB;
const socialTidal = import.meta.env.PUBLIC_SOCIAL_TIDAL;
const socialSpotify = import.meta.env.PUBLIC_SOCIAL_SPOTIFY;
const socialInstagram = import.meta.env.PUBLIC_SOCIAL_INSTAGRAM;
const socialAppleMusic = import.meta.env.PUBLIC_SOCIAL_APPLE_MUSIC;
---

<div
  class="flex items-center gap-1 flex-wrap"
  data-social-links-bar
  data-tracks={allTracksJson}
>
  {/* Play All button */}
  <button
    id="play-all-btn"
    class="flex items-center justify-center mr-3 w-10 h-10 bg-accent rounded-full text-black transition-colors hover:bg-accent-hover"
    aria-label="Play all tracks"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-5 h-5"
    >
      <polygon points="7 3 21 12 7 21 7 3"></polygon>
    </svg>
  </button>

  {/* Social/streaming icon links — rendered only when URL is configured */}
  <a
    href={socialImdb}
    aria-label="IMDB"
    class="group flex items-center justify-center w-5 h-5 text-text-secondary transition-colors hover:text-text relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="w-4 h-4"
    >
      <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect>
      <path d="M7 2v20"></path>
      <path d="M17 8l-4 4 4 4"></path>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text-secondary whitespace-nowrap"
      >IMDB</span
    >
  </a>

  <a
    href={socialTidal}
    aria-label="Tidal"
    class="group flex items-center justify-center w-5 h-5 text-text-secondary transition-colors hover:text-text relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-4 h-4"
    >
      <path
        d="M12 2L6.5 7.5 12 13l5.5-5.5L12 2zm0 11L6.5 18.5 12 24l5.5-5.5L12 13z"
      ></path>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text-secondary whitespace-nowrap"
    >
      Tidal
    </span>
  </a>

  <a
    href={socialSpotify}
    aria-label="Spotify"
    class="group flex items-center justify-center w-5 h-5 text-text-secondary transition-colors hover:text-text relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-4 h-4"
    >
      <path
        d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381C8.64 5.801 15.6 6.06 19.8 8.82c.5.3.66 1.02.36 1.56-.3.42-1.02.6-1.56.3z"
      ></path>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text-secondary whitespace-nowrap"
    >
      Spotify
    </span>
  </a>

  <a
    href={socialInstagram}
    aria-label="Instagram"
    class="group flex items-center justify-center w-5 h-5 text-text-secondary transition-colors hover:text-text relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="w-4 h-4"
    >
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text-secondary whitespace-nowrap"
    >
      Instagram
    </span>
  </a>

  <a
    href={socialAppleMusic}
    aria-label="Apple Music"
    class="group flex items-center justify-center w-5 h-5 text-text-secondary transition-colors hover:text-text relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0.22 1.25 20.56 24.61"
      fill="currentColor"
      class="w-4 h-4"
    >
      <path
        d="M17.39 14.21c0-2.022 0.93-3.5 2.734-4.648-1.038-1.476-2.57-2.24-4.592-2.406-1.97-0.164-4.102 1.094-4.868 1.094-0.82 0-2.68-1.04-4.156-1.04C3.446 7.266 0.218 9.62 0.218 14.484c0 1.422 0.22 2.9 0.766 4.43 0.712 2.024 3.226 6.946 5.852 6.836 1.368 0 2.352-0.984 4.156-0.984 1.75 0 2.626 0.984 4.156 0.984 2.68 0 4.978-4.484 5.634-6.508-3.556-1.696-3.392-4.92-3.392-5.032m-3.06-8.968c1.474-1.75 1.31-3.39 1.31-3.992-1.312 0.11-2.844 0.93-3.72 1.914-0.982 1.094-1.53 2.46-1.42 3.938 1.42 0.108 2.734-0.602 3.828-1.86"
      ></path>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text-secondary whitespace-nowrap"
    >
      Apple Music
    </span>
  </a>

  <button
    type="button"
    id="contact-btn"
    aria-label="Contact"
    class="border border-white/50 rounded-full ml-3 px-3 py-1.5 text-xs text-text transition-colors hover:bg-text hover:text-bg cursor-pointer"
  >
    Contact
  </button>
</div>

<script>
  import { isPlaying, playbackState, tracks } from '../components/AudioPlayer/playlistStore';
  import { effect } from '@preact/signals';
  import { togglePlayer } from '../scripts/audio-player-events';

  // Play All / Play-Pause toggle button
  const wrapper = document.querySelector('[data-social-links-bar]');
  const playAllBtn = document.getElementById('play-all-btn');

  if (wrapper && playAllBtn) {
    const tracksJson = wrapper.getAttribute('data-tracks');

    playAllBtn.addEventListener('click', () => {
      if (playbackState.value === 'idle' || tracks.value.length === 0) {
        // No track loaded — start the full playlist from scratch
        if (tracksJson) {
          const parsedTracks = JSON.parse(tracksJson);
          document.dispatchEvent(
            new CustomEvent('audio-player:play', {
              detail: { tracks: parsedTracks, startIndex: 0 },
            }),
          );
        }
      } else {
        // Track loaded — toggle play/pause
        togglePlayer();
      }
    });

    // Reactive icon + aria-label sync with player bar state
    effect(() => {
      const playing = isPlaying.value;
      if (playing) {
        // Pause icon (two vertical bars)
        playAllBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><rect x="6" y="4" width="4" height="16" rx="1" /><rect x="14" y="4" width="4" height="16" rx="1" /></svg>`;
        playAllBtn.setAttribute('aria-label', 'Pause');
      } else if (playbackState.value === 'idle' || tracks.value.length === 0) {
        // Play triangle — idle state
        playAllBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><polygon points="7 3 21 12 7 21 7 3"></polygon></svg>`;
        playAllBtn.setAttribute('aria-label', 'Play all tracks');
      } else {
        // Play triangle — paused state
        playAllBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><polygon points="7 3 21 12 7 21 7 3"></polygon></svg>`;
        playAllBtn.setAttribute('aria-label', 'Play');
      }
    });
  }

  // Contact button: dispatch contact-modal:open event
  const contactBtn = document.getElementById('contact-btn');
  if (contactBtn) {
    contactBtn.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('contact-modal:open'));
    });
  }
</script>
