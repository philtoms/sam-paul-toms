---
/**
 * SocialLinksBar — Play All button + social/streaming icon links.
 *
 * A pure Astro component with a client-side script handling Play All clicks.
 * Follows the same pattern as TrackList.astro to dispatch audio events.
 *
 * Each social icon link reveals its platform name via a smooth CSS
 * opacity transition on hover (200ms ease). The label appears below the
 * icon in a white-bordered pill. Icons remain stationary — no layout shift.
 *
 * Props:
 * - allTracksJson: Pre-serialized JSON string of Track[] objects.
 *   The script tag parses it and dispatches the audio-player:play event.
 */

interface Props {
  allTracksJson: string;
}

const { allTracksJson } = Astro.props;
---

<div
  class="flex items-center gap-2 flex-wrap"
  data-social-links-bar
  data-tracks={allTracksJson}
>
  {/* Play All button */}
  <button
    id="play-all-btn"
    class="flex items-center justify-center w-10 h-10 bg-yellow-500 rounded-full text-black transition-colors hover:bg-yellow-400"
    aria-label="Play all tracks"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-5 h-5"
    >
      <polygon points="7 3 21 12 7 21 7 3"></polygon>
    </svg>
  </button>

  {/* Social/streaming icon links */}
  <a
    href="#"
    aria-label="IMDB"
    class="group flex items-center justify-center w-5 h-5 text-text/50 transition-colors hover:text-accent relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="w-4 h-4"
    >
      <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect>
      <path d="M7 2v20"></path>
      <path d="M17 8l-4 4 4 4"></path>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text/70 whitespace-nowrap"
      >IMDB</span
    >
  </a>

  <a
    href="#"
    aria-label="Tidal"
    class="group flex items-center justify-center w-5 h-5 text-text/50 transition-colors hover:text-accent relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-4 h-4"
    >
      <path
        d="M12 2L6.5 7.5 12 13l5.5-5.5L12 2zm0 11L6.5 18.5 12 24l5.5-5.5L12 13z"
      ></path>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text/70 whitespace-nowrap"
      >Tidal</span
    >
  </a>

  <a
    href="#"
    aria-label="Spotify"
    class="group flex items-center justify-center w-5 h-5 text-text/50 transition-colors hover:text-accent relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-4 h-4"
    >
      <path
        d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381C8.64 5.801 15.6 6.06 19.8 8.82c.5.3.66 1.02.36 1.56-.3.42-1.02.6-1.56.3z"
      ></path>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text/70 whitespace-nowrap"
      >Spotify</span
    >
  </a>

  <a
    href="#"
    aria-label="Instagram"
    class="group flex items-center justify-center w-5 h-5 text-text/50 transition-colors hover:text-accent relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="w-4 h-4"
    >
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text/70 whitespace-nowrap"
      >Instagram</span
    >
  </a>

  <a
    href="#"
    aria-label="Apple Music"
    class="group flex items-center justify-center w-5 h-5 text-text/50 transition-colors hover:text-accent relative"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-4 h-4"
    >
      <path
        fill="currentColor"
        d="M8.695 7.105c0-1.011.465-1.75 1.367-2.324-.519-.738-1.285-1.12-2.296-1.203-.985-.082-2.051.547-2.434.547-.41 0-1.34-.52-2.078-.52C1.723 3.633.109 4.81.109 7.242c0 .711.11 1.45.383 2.215.356 1.012 1.613 3.473 2.926 3.418.684 0 1.176-.492 2.078-.492.875 0 1.313.492 2.078.492 1.34 0 2.489-2.242 2.817-3.254-1.778-.848-1.696-2.46-1.696-2.516m-1.53-4.484c.737-.875.655-1.695.655-1.996-.656.055-1.422.465-1.86.957-.491.547-.765 1.23-.71 1.969.71.054 1.367-.301 1.914-.93"
      ></path>
    </svg>
    <span
      class="absolute top-full mt-1.5 opacity-0 transition-opacity duration-200 group-hover:opacity-100 border border-white/50 rounded-sm px-2 py-0.5 text-xs font-bold text-text/70 whitespace-nowrap"
      >Apple Music</span
    >
  </a>

  <a
    href="/about"
    aria-label="Contact"
    class="border border-white/50 rounded-full px-3 py-0.5 text-xs font-bold text-text/70 transition-colors hover:text-accent"
  >
    Contact
  </a>
</div>

<script>
  // Play All button: parse tracks from data-tracks and dispatch audio-player:play event
  const wrapper = document.querySelector('[data-social-links-bar]');
  const playAllBtn = document.getElementById('play-all-btn');

  if (wrapper && playAllBtn) {
    const tracksJson = wrapper.getAttribute('data-tracks');
    if (tracksJson) {
      const tracks = JSON.parse(tracksJson);
      playAllBtn.addEventListener('click', () => {
        document.dispatchEvent(
          new CustomEvent('audio-player:play', {
            detail: { tracks, startIndex: 0 },
          }),
        );
      });
    }
  }
</script>
