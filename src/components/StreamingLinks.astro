---
interface Props {
  links: {
    spotify?: string;
    appleMusic?: string;
    youtubeMusic?: string;
    bandcamp?: string;
  };
}

const { links } = Astro.props;

const platforms = [
  {
    name: 'Spotify',
    url: links.spotify,
