  },
  {
    name: 'Apple Music',
    url: links.appleMusic,
    color: 'hover:text-[#FA2D48]',
    viewBox: '0.22 1.25 20.56 24.61',
    icon: 'M17.39 14.21c0-2.022 0.93-3.5 2.734-4.648-1.038-1.476-2.57-2.24-4.592-2.406-1.97-0.164-4.102 1.094-4.868 1.094-0.82 0-2.68-1.04-4.156-1.04C3.446 7.266 0.218 9.62 0.218 14.484c0 1.422 0.22 2.9 0.766 4.43 0.712 2.024 3.226 6.946 5.852 6.836 1.368 0 2.352-0.984 4.156-0.984 1.75 0 2.626 0.984 4.156 0.984 2.68 0 4.978-4.484 5.634-6.508-3.556-1.696-3.392-4.92-3.392-5.032m-3.06-8.968c1.474-1.75 1.31-3.39 1.31-3.992-1.312 0.11-2.844 0.93-3.72 1.914-0.982 1.094-1.53 2.46-1.42 3.938 1.42 0.108 2.734-0.602 3.828-1.86',
  },
  {
    name: 'YouTube Music',
    url: links.youtubeMusic,
    color: 'hover:text-[#FF0000]',
    viewBox: '0 0 24 24',
    icon: 'M12 0C5.376 0 0 5.376 0 12s5.376 12 12 12 12-5.376 12-12S18.624 0 12 0zm0 19.104c-3.924 0-7.104-3.18-7.104-7.104S8.076 4.896 12 4.896s7.104 3.18 7.104 7.104-3.18 7.104-7.104 7.104zm0-13.332c-3.432 0-6.228 2.796-6.228 6.228S8.568 18.228 12 18.228 18.228 15.432 18.228 12 15.432 5.772 12 5.772zM9.684 15.54V8.46L15.816 12l-6.132 3.54z',
  },
  {
    name: 'Bandcamp',
    url: links.bandcamp,
    color: 'hover:text-[#1DA0C3]',
    viewBox: '0 0 24 24',
    icon: 'M0 18.75l7.437-13.5H24l-7.438 13.5z',
  },
];

const available = platforms.filter((p) => p.url);
---

{available.length > 0 && (
  <div class="flex flex-wrap items-center gap-3">
    {available.map((platform) => (
      <a
        href={platform.url}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'inline-flex items-center gap-2 text-sm text-text/60 transition-colors duration-200',
          platform.color,
        ]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox={platform.viewBox}
          class="w-5 h-5 fill-current"
        >
          <path d={platform.icon} />
        </svg>
        <span>{platform.name}</span>
      </a>
    ))}
  </div>
)}
