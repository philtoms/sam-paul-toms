  },
  {
    name: 'Apple Music',
    url: links.appleMusic,
    color: 'hover:text-[#FA2D48]',
    icon: 'M23.994 6.124a9.23 9.23 0 00-.24-2.19c-.317-1.31-1.062-2.31-2.18-3.043A5.022 5.022 0 0019.7.175a10.16 10.16 0 00-1.564-.073C17.342.033 16.547.01 15.753 0H8.247c-.793.01-1.589.033-2.383.102A10.16 10.16 0 004.3.175a5.022 5.022 0 00-1.874.716C1.309 1.624.564 2.624.247 3.934a9.23 9.23 0 00-.24 2.19C.024 6.392 0 6.726 0 7.06v9.88c0 .334.024.668.063 1.005a9.23 9.23 0 00.24 2.19c.317 1.31 1.062 2.31 2.18 3.043a5.022 5.022 0 001.874.716c.63.118 1.27.17 1.912.18.447.01.894.018 1.342.026h11.778c.448-.008.895-.016 1.342-.026a10.16 10.16 0 001.564-.073 5.022 5.022 0 001.874-.716c1.118-.733 1.863-1.733 2.18-3.043a9.23 9.23 0 00.24-2.19c.039-.337.063-.671.063-1.005V7.06c0-.334-.024-.668-.063-1.005zM15.75 15.75h-2.25v-6.75c0-.828-.672-1.5-1.5-1.5s-1.5.672-1.5 1.5v8.25c0 .828.672 1.5 1.5 1.5h3.75c.828 0 1.5-.672 1.5-1.5s-.672-1.5-1.5-1.5z',
  },
  {
    name: 'YouTube Music',
    url: links.youtubeMusic,
    color: 'hover:text-[#FF0000]',
    icon: 'M12 0C5.376 0 0 5.376 0 12s5.376 12 12 12 12-5.376 12-12S18.624 0 12 0zm0 19.104c-3.924 0-7.104-3.18-7.104-7.104S8.076 4.896 12 4.896s7.104 3.18 7.104 7.104-3.18 7.104-7.104 7.104zm0-13.332c-3.432 0-6.228 2.796-6.228 6.228S8.568 18.228 12 18.228 18.228 15.432 18.228 12 15.432 5.772 12 5.772zM9.684 15.54V8.46L15.816 12l-6.132 3.54z',
  },
  {
    name: 'Bandcamp',
    url: links.bandcamp,
    color: 'hover:text-[#1DA0C3]',
    icon: 'M0 18.75l7.437-13.5H24l-7.438 13.5z',
  },
];

const available = platforms.filter((p) => p.url);
---

{available.length > 0 && (
  <div class="flex flex-wrap items-center gap-3">
    {available.map((platform) => (
      <a
        href={platform.url}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'inline-flex items-center gap-2 text-sm text-text/60 transition-colors duration-200',
          platform.color,
        ]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="w-5 h-5 fill-current"
        >
          <path d={platform.icon} />
        </svg>
        <span>{platform.name}</span>
      </a>
    ))}
  </div>
)}
