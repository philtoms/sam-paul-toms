---
interface Props {
  quotes: Array<{ text: string; source: string; url?: string }>;
}

const { quotes } = Astro.props;
---

{quotes.length > 0 && (
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {quotes.map((quote) => (
      <figure class="bg-white/5 rounded-lg p-6 border border-white/10">
        <span aria-hidden="true" class="block text-accent text-4xl opacity-60 leading-none select-none">&ldquo;</span>
        <blockquote class="text-white/90 text-lg italic mt-2">
          <p>{quote.text}</p>
        </blockquote>
        <figcaption class="mt-4 text-white/50 text-sm">
          &mdash;{quote.url ? (
            <cite>
              <a href={quote.url} class="hover:text-accent transition-colors duration-200" target="_blank" rel="noopener noreferrer">
                {quote.source}
              </a>
            </cite>
          ) : (
            <cite>{quote.source}</cite>
          )}
        </figcaption>
      </figure>
    ))}
  </div>
)}
