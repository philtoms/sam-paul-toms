---
interface Props {
  release: {
    id: string;
    data: {
      title: string;
      artist: string;
      releaseDate: Date;
      type: 'album' | 'ep' | 'single';
      artwork: string;
    };
  };
  showType?: boolean;
}

const { release, showType = true } = Astro.props;
const slug = release.id;
const { title, artist, releaseDate, type, artwork } = release.data;

const formattedDate = releaseDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const typeBadge: Record<string, string> = {
  album: 'ALBUM',
  ep: 'EP',
  single: 'SINGLE',
};
---

<a
  href={`/releases/${slug}`}
  class="group block rounded-lg overflow-hidden bg-white/5 transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:shadow-accent/10"
>
  <div class="aspect-square overflow-hidden">
    <img
      src={artwork}
      alt={`${title} artwork`}
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </div>
  <div class="p-4">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-bold text-sm leading-tight truncate">{title}</h3>
      {showType && (
        <span class="shrink-0 text-[10px] font-semibold tracking-wider text-accent bg-accent/10 px-2 py-0.5 rounded">
          {typeBadge[type]}
        </span>
      )}
    </div>
    <p class="text-xs text-text/60 mt-1">{artist}</p>
    <p class="text-xs text-text/40 mt-0.5">{formattedDate}</p>
  </div>
</a>
