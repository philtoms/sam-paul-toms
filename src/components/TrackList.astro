---
interface Track {
  title: string;
  duration: string;
  spotifyUrl?: string;
  appleMusicUrl?: string;
  youtubeMusicUrl?: string;
  bandcampUrl?: string;
  audioFile?: string;
}

interface Props {
  tracks: Track[];
}

const { tracks } = Astro.props;

function hasStreamingLinks(track: Track): boolean {
  return !!(track.spotifyUrl || track.appleMusicUrl || track.youtubeMusicUrl || track.bandcampUrl);
}
---

<ol class="w-full">
  {tracks.map((track, i) => (
    <li
      class:list={[
        'group flex items-center gap-4 px-4 py-3 rounded-md transition-colors duration-150',
        i % 2 === 1 ? 'bg-white/5' : '',
      ]}
    >
      {/* Track number / play icon */}
      <span class="relative w-6 text-center shrink-0 text-sm text-text/40 tabular-nums">
        <span class="group-hover:hidden">{String(i + 1).padStart(2, '0')}</span>
        <span class="hidden group-hover:inline text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 inline">
            <path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd" />
          </svg>
        </span>
      </span>

      {/* Track title */}
      <span class="flex-1 truncate text-sm">{track.title}</span>

      {/* Streaming indicator */}
      {hasStreamingLinks(track) && (
        <span class="shrink-0 text-text/30 group-hover:text-accent/60 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
            <path d="M11.983 1.907a.75.75 0 0 0-1.292-.657l-8.5 9.5A.75.75 0 0 0 2.75 12h6.572l-1.305 6.093a.75.75 0 0 0 1.292.657l8.5-9.5A.75.75 0 0 0 17.25 8h-6.572l1.305-6.093Z" />
          </svg>
        </span>
      )}

      {/* Duration */}
      <span class="shrink-0 text-sm text-text/40 tabular-nums">{track.duration}</span>
    </li>
  ))}
</ol>
