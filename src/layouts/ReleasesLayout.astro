---
import BaseLayout from './BaseLayout.astro';
import { DEFAULT_SITE_NAME } from '../scripts/seo-helpers';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'music.song' | 'music.album' | 'music.playlist';
  structuredData?: object | object[];
  noindex?: boolean;
}

const siteName = import.meta.env.PUBLIC_SITE_NAME || DEFAULT_SITE_NAME;

const {
  title = `${siteName} — Releases`,
  description,
  image,
  canonicalUrl,
  type,
  structuredData,
  noindex,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  canonicalUrl={canonicalUrl}
  type={type}
  structuredData={structuredData}
  noindex={noindex}
>
  <div class="max-w-[1052px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="mb-8 text-sm text-text/50">
      <a href="/" class="hover:text-accent transition-colors">{siteName}</a>
      <span class="mx-2">/</span>
      <span class="text-text/80">Releases</span>
    </nav>
    <slot />
  </div>
</BaseLayout>
