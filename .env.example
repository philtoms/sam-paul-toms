# === Deployment (Cloudflare Pages + R2) ===

# Public URL where audio files are served
# Local dev with Wrangler: http://localhost:4321/r2
# Local dev with placeholder audio (see scripts/setup-dev-audio.sh): http://localhost:4321/audio-samples
# Production: your R2 bucket's public access URL (e.g., https://pub-xxxx.r2.dev)
#
# Audio URLs are constructed as: ${R2_PUBLIC_URL}/${track-relative-path}
# Example: R2_PUBLIC_URL/releases/midnight-sessions/01-track.mp3
R2_PUBLIC_URL=http://localhost:4321/r2

# Site URL used for canonical tags, sitemap, and structured data
# Production: your actual domain (e.g., https://sam.music)
# If not set, defaults to https://sam.music
SITE_URL=https://sam.music

# === Analytics ===

# Umami Analytics (leave blank to disable tracking in development)
# PUBLIC_UMAMI_SRC is the full URL to the Umami tracking script
#   (e.g., https://analytics.example.com/script.js)
# PUBLIC_UMAMI_WEBSITE_ID is the UUID from the Umami dashboard
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SRC=

# === Social Links ===

# Artist-specific social and streaming profile URLs.
# Leave blank to hide the corresponding icon from the social links bar.
# These are used by SocialLinksBar.astro to link to the artist's profiles.
#
# Example values:
#   PUBLIC_SOCIAL_IMDB=https://www.imdb.com/name/nm1234567/
#   PUBLIC_SOCIAL_TIDAL=https://tidal.com/artist/12345
#   PUBLIC_SOCIAL_SPOTIFY=https://open.spotify.com/artist/abc123
#   PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/artistname/
#   PUBLIC_SOCIAL_APPLE_MUSIC=https://music.apple.com/artist/12345
PUBLIC_SOCIAL_IMDB=
PUBLIC_SOCIAL_TIDAL=
PUBLIC_SOCIAL_SPOTIFY=
PUBLIC_SOCIAL_INSTAGRAM=
PUBLIC_SOCIAL_APPLE_MUSIC=

# WhatsApp phone number for the "Message on WhatsApp" link in the contact modal.
# Format: international number without + or spaces (e.g., 447123456789).
# Leave blank to hide the WhatsApp link from the contact modal.
PUBLIC_WHATSAPP_PHONE=

# === Theme ===

# Site-wide accent/brand colour (hex). Controls play buttons, focus rings,
# waveform progress bars, and all accent highlights. Default: "#852929" (teal)
PUBLIC_ACCENT_COLOR="#852929"

# === Contact Form (Resend) ===

# Resend API key for sending contact form emails.
# Get yours at https://resend.com — free tier: 3,000 emails/month.
# Server-only variable (no PUBLIC_ prefix).
RESEND_API_KEY=

# Email address that receives contact form submissions.
# Server-only variable (no PUBLIC_ prefix).
CONTACT_RECIPIENT_EMAIL=

# Verified sender address for contact form emails (notification + auto-reply).
# In development, use Resend's default sender: onboarding@resend.dev
# In production, use a verified domain address (e.g., noreply@sampaultoms.uk).
# Server-only variable (no PUBLIC_ prefix).
CONTACT_FROM_EMAIL=
