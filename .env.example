# Base URL for Cloudflare R2 object storage (used by audio player and release assets).
# For local development with Wrangler's R2 emulation, use:
#   http://localhost:8788/r2
# For production, set this to your R2 public bucket URL.

# Audio URLs are constructed as: ${R2_PUBLIC_URL}/${track-relative-path}
# Example: R2_PUBLIC_URL/albums/my-album/01-track.mp3
R2_PUBLIC_URL=http://localhost:8788/r2

# Umami Analytics (leave blank to disable tracking in development)
# PUBLIC_UMAMI_SRC is the full URL to the Umami tracking script
#   (e.g., https://analytics.example.com/script.js)
# PUBLIC_UMAMI_WEBSITE_ID is the UUID from the Umami dashboard
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SRC=
